# Copy this to .env.local

# SQLite for local dev (Prisma)
DATABASE_URL="file:./dev.db"

# Generate a long random string: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Python CV service URL (run: cd cv-service && uvicorn main:app --reload)
CV_SERVICE_URL="http://localhost:8000"

# Set to "true" to use mock YOLO detections (no Python needed for frontend demo)
CV_MOCK_MODE="false"
